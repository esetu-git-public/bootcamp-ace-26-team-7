# Supabase Credentials
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Frontend (Vite reads these via envDir: ".." from vite.config.ts)
VITE_API_BASE_URL=http://localhost:8501
VITE_GITHUB_OAUTH_REDIRECT=http://localhost:5173/auth/github/callback

# JWT Secret (used to sign auth tokens)
JWT_SECRET=change-this-to-a-random-secret

# Admin Credentials
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your_secure_password
ADMIN_NAME=Admin

# App URL (OAuth redirect target — set to your deployed HF Space URL in production)
APP_URL=https://amruthjakku-surface-crack-detection.hf.space/login

# GitHub OAuth (configured in Supabase Dashboard → Authentication → Providers → GitHub)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=